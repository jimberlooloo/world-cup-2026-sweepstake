# Copy to .streamlit/secrets.toml for local dev (that file is gitignored), or paste the
# chosen block into the Streamlit Community Cloud app's Secrets panel. NEVER commit real names.
#
# Generate either block with:  python draw.py "Alice, Bob, ... (16 names)"

# --- Shape A: names + seed (the app draws; reproducible) -----------------------
[sweepstake]
seed = 20260611
players = [
  "Player 1", "Player 2", "Player 3", "Player 4",
  "Player 5", "Player 6", "Player 7", "Player 8",
  "Player 9", "Player 10", "Player 11", "Player 12",
  "Player 13", "Player 14", "Player 15", "Player 16",
]

# --- Shape B: an explicit, already-drawn mapping (use instead of the above) -----
# [sweepstake.allocation]
# "Alice" = ["Brazil", "Japan", "Ghana"]
# "Bob"   = ["France", "Iran", "Norway"]
# ... one line per player, exactly 3 team names each (must match the feed spelling)
